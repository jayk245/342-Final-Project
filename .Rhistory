library(knitr)
data <- data.frame(
Group = c("BNT162b2", "Placebo", "Total"),
Cases = c(8, 162, 170),
Sample_Size = c(17411, 17511, 34922)
)
kable(data, col.names = c("Group", "Cases", "Sample Size"),
caption = "Table 1: Vaccine Efficacy against COVID-19 at least 7 days after second dose")
git add .
#Use this code chunk to include libraries, and set global options.
library(fastR2)
library(ggplot2)
library(HDInterval)
loglik.pi <- function(pi, v, n) {
ifelse((pi <= 0 | pi >= 1), NA,
v * log(pi) + (n - v) * log(1 - pi)
)
}
ml.pi <- maxLik2(loglik = loglik.pi,
start = 0.5,
v = 8,
n = 170)
plot(ml.pi) +
labs(title = "Second Order Approximation of Log-Likelihood",
subtitle = "n = 170, t = 8",
x = expression(pi),
y = "Log-Likelihood")
#Second order approximation
loglik.pi <- function(pi, v, n) {
ifelse((pi <= 0 | pi >= 1), NA,
v * log(pi) + (n - v) * log(1 - pi)
)
}
ml.pi <- maxLik2(loglik = loglik.pi,
start = 0.5,
v = 8,
n = 170)
plot(ml.pi) +
labs(title = "Second order approximation",
subtitle = "n = 170, t = 8",
x = expression(pi),
y = "Log-Likelihood")
